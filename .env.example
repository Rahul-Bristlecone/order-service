# Order Service Configuration

# Database Configuration
MYSQL_USER=order_user
MYSQL_PASSWORD=order_password
DB_HOST=mysql
DB_PORT=3306
MYSQL_DATABASE=order_db

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-here

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Redis Configuration (for session management)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# External Service URLs (for validation)
# Update these based on your service deployment
CUSTOMER_SERVICE_URL=http://127.0.0.1:5006
COMPANY_SERVICE_URL=http://127.0.0.1:5005
LOCATION_SERVICE_URL=http://127.0.0.1:5002
PRODUCT_SERVICE_URL=http://127.0.0.1:5003

# Service Request Timeout (seconds)
SERVICE_REQUEST_TIMEOUT=5
